{
  "name": "@mikara89/cap-transport-azure-servicebus",
  "version": "2.2.0",
  "description": "Azure Service Bus transport adapter for CAP",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "homepage": "https://mikara89.github.io/cap-nodejs/",
  "repository": {
    "type": "git",
    "url": "https://github.com/mikara89/cap-nodejs",
    "directory": "libs/cap-transport-azure-servicebus"
  },
  "bugs": {
    "url": "https://github.com/mikara89/cap-nodejs/issues"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.lib.json",
    "prepack": "npm run build",
    "test": "jest",
    "lint": "eslint \"src/**/*.ts\" --fix"
  },
  "dependencies": {
    "@azure/service-bus": "^7.9.0"
  },
  "peerDependencies": {
    "@mikara89/cap-core": "^2.2.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "reflect-metadata": "^0.2.0"
  },
  "devDependencies": {
    "@mikara89/cap-core": "file:../cap-core",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./nest": {
      "types": "./dist/nest/index.d.ts",
      "require": "./dist/nest/index.js",
      "default": "./dist/nest/index.js"
    },
    "./nest/*": {
      "types": "./dist/nest/*.d.ts",
      "require": "./dist/nest/*.js",
      "default": "./dist/nest/*.js"
    },
    "./servicebus-transport.module": {
      "types": "./dist/servicebus-transport.module.d.ts",
      "require": "./dist/servicebus-transport.module.js",
      "default": "./dist/servicebus-transport.module.js"
    },
    "./dist/*": "./dist/*",
    "./package.json": "./package.json"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": true
    },
    "@nestjs/core": {
      "optional": true
    },
    "reflect-metadata": {
      "optional": true
    }
  }
}
