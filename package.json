{
  "name": "cap-nodejs",
  "version": "2.4.1",
  "description": "Framework-agnostic Node.js CAP reliable messaging packages.",
  "author": "",
  "homepage": "https://mikara89.github.io/cap-nodejs/",
  "repository": {
    "type": "git",
    "url": "https://github.com/mikara89/cap-nodejs"
  },
  "bugs": {
    "url": "https://github.com/mikara89/cap-nodejs/issues"
  },
  "private": true,
  "workspaces": [
    "libs/*"
  ],
  "license": "MIT",
  "scripts": {
    "build": "npm run build:libs && nest build",
    "build:libs": "node tools/workspace-packages.js run --script build",
    "bootstrap": "npm install",
    "build:libs:lerna": "npx lerna run build --stream",
    "---------------------------------------------------------------------": "--- affected-package validation ---",
    "check:affected": "npx lerna ls --since=origin/main --all",
    "lint:affected": "npx lerna exec --since=origin/main -- eslint \"src/**/*.ts\"",
    "build:affected": "npx lerna run build --since=origin/main",
    "test:affected": "npx lerna run test --since=origin/main",
    "pack:dry-run:affected": "npx lerna exec --since=origin/main -- npm pack --dry-run",
    "graph:affected": "npx lerna ls --since=origin/main --all --json",
    "--------------------------------------------------------------------": "--- release ---",
    "release": "node tools/release-tool.js plan --operation release --channel stable --coordinated-major false",
    "release:verify": "node tools/release-tool.js verify && node tools/verify-legacy-package-names.js",
    "release:baseline": "node tools/release-tool.js baseline",
    "release:plan": "node tools/release-tool.js plan",
    "packages:list": "node tools/workspace-packages.js list",
    "packages:verify": "node tools/workspace-packages.js verify",
    "build:lib:cap-core": "cd libs/cap-core && tsc -p tsconfig.lib.json",
    "build:lib:cap-testing": "cd libs/cap-testing && tsc -p tsconfig.lib.json",
    "build:lib:cap-nest": "cd libs/cap-nest && tsc -p tsconfig.lib.json",
    "build:lib:cap-express": "cd libs/cap-express && tsc -p tsconfig.lib.json",
    "build:lib:cap-dashboard-core": "cd libs/cap-dashboard-core && tsc -p tsconfig.lib.json",
    "build:lib:cap-dashboard-nest": "npm run build --workspace @mikara89/cap-dashboard-nest",
    "build:lib:cap-dashboard": "npm run build --workspace @mikara89/cap-dashboard",
    "build:lib:cap-dashboard-express": "cd libs/cap-dashboard-express && tsc -p tsconfig.lib.json",
    "build:lib:cap-storage-mikro-orm": "cd libs/cap-storage-mikro-orm && tsc -p tsconfig.lib.json",
    "build:lib:cap-storage-knex": "cd libs/cap-storage-knex && tsc -p tsconfig.lib.json",
    "build:lib:cap-storage-typeorm": "cd libs/cap-storage-typeorm && tsc -p tsconfig.lib.json",
    "build:lib:cap-storage-prisma": "npm run build --workspace @mikara89/cap-storage-prisma",
    "build:lib:cap-transport-azure-servicebus": "cd libs/cap-transport-azure-servicebus && tsc -p tsconfig.lib.json",
    "build:lib:cap-transport-nestjs-microservices": "cd libs/cap-transport-nestjs-microservices && tsc -p tsconfig.lib.json",
    "build:lib:cap-transport-rabbitmq": "cd libs/cap-transport-rabbitmq && tsc -p tsconfig.lib.json",
    "build:lib:cap-transport-kafka": "cd libs/cap-transport-kafka && tsc -p tsconfig.lib.json",
    "build:lib:cap-transport-aws-sns-sqs": "cd libs/cap-transport-aws-sns-sqs && tsc -p tsconfig.lib.json",
    "prestart": "npm run build",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "fallow": "fallow",
    "fallow:audit": "fallow audit",
    "fallow:health": "fallow health --score --hotspots --targets --group-by package",
    "fallow:health:ci": "node tools/check-fallow-health-score.js 70",
    "fallow:dead-code": "fallow dead-code --group-by package",
    "fallow:dupes": "fallow dupes --group-by package",
    "fallow:ci": "fallow audit --format compact --gate all",
    "start": "nest start cap-test-app",
    "start:dev": "nest start cap-test-app --watch",
    "start:debug": "nest start cap-test-app --debug --watch",
    "start:prod": "node dist/apps/cap-test-app/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:check": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "docs:api": "node node_modules/typedoc/dist/lib/cli.js",
    "examples:check": "tsc -p examples/tsconfig.json --noEmit",
    "pack:dry-run": "node tools/workspace-packages.js pack --dry-run",
    "pack:smoke:rabbitmq": "node tools/verify-rabbitmq-pack.js",
    "pack:smoke:kafka": "node tools/verify-kafka-pack.js",
    "pack:smoke:aws-sns-sqs": "node tools/verify-aws-sns-sqs-pack.js",
    "pack:smoke:storage-nest": "node tools/verify-storage-nest-packs.js",
    "pack:smoke:dashboard-isolation": "node tools/verify-dashboard-isolation.js",
    "test:integration:servicebus": "node tools/run-servicebus-integration.js",
    "test:integration:rabbitmq": "jest --testRegex=rabbitmq\\.integration\\.spec\\.ts$ --runInBand",
    "test:integration:kafka": "jest --testRegex=kafka\\.integration\\.spec\\.ts$ --runInBand",
    "test:integration:aws-sns-sqs": "jest --testRegex=aws-sns-sqs\\.integration\\.spec\\.ts$ --runInBand",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:lib:cap-core": "jest --testPathPattern=libs/cap-core",
    "test:lib:cap-testing": "jest --testPathPattern=libs/cap-testing",
    "test:lib:cap-nest": "jest --testPathPattern=libs/cap-nest",
    "test:lib:cap-express": "jest --testPathPattern=libs/cap-express",
    "test:lib:cap-transport-rabbitmq": "jest --testPathPattern=libs/cap-transport-rabbitmq/src",
    "test:lib:cap-transport-kafka": "jest --testPathPattern=libs/cap-transport-kafka/src",
    "test:lib:cap-transport-aws-sns-sqs": "jest --testPathPattern=libs/cap-transport-aws-sns-sqs/src",
    "test:lib:cap-dashboard-core": "jest --testPathPattern=libs/cap-dashboard-core",
    "test:lib:cap-dashboard-nest": "jest --testPathPattern=libs/cap-dashboard-nest",
    "test:lib:cap-dashboard-express": "jest --testPathPattern=libs/cap-dashboard-express",
    "test:lib:cap-storage-knex": "jest --testPathPattern=libs/cap-storage-knex",
    "test:lib:cap-storage-typeorm": "jest --testPathPattern=libs/cap-storage-typeorm",
    "test:lib:cap-storage-prisma": "npm run generate:test-clients --workspace @mikara89/cap-storage-prisma && jest --testPathPattern=libs/cap-storage-prisma/src",
    "test:lib:cap-storage-mikro-orm": "jest --testPathPattern=libs/cap-storage-mikro-orm",
    "test:lib:cap-transport-azure-servicebus": "jest --testPathPattern=libs/cap-transport-azure-servicebus",
    "test:lib:cap-transport-nestjs-microservices": "jest --testPathPattern=libs/cap-transport-nestjs-microservices",
    "test:lib:cap-dashboard": "jest --testPathPattern=libs/cap-dashboard",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./apps/cap-test-app/test/jest-e2e.json",
    "test:integration:db": "npm run generate:test-clients --workspace @mikara89/cap-storage-prisma && jest --testRegex=.*outbox-claim.* --runInBand",
    "test:integration:db:postgres": "npm run generate:test-clients --workspace @mikara89/cap-storage-prisma && jest --testRegex=.*outbox-claim.* --testNamePattern=PostgreSQL --runInBand",
    "test:integration:db:mysql": "npm run generate:test-clients --workspace @mikara89/cap-storage-prisma && jest --testRegex=.*outbox-claim.* --testNamePattern=MySQL --runInBand",
    "test:integration": "jest --config ./apps/cap-test-app/test/jest-integration.json",
    "test:release-tooling": "node --test tools/workspace-packages.test.js tools/release-tool.test.js",
    "verify:legacy-package-names": "node tools/verify-legacy-package-names.js",
    "test:legacy-package-names": "node --test tools/verify-legacy-package-names.test.js"
  },
  "dependencies": {
    "@mikro-orm/better-sqlite": "^6.0.0",
    "@mikro-orm/core": "^6.0.0",
    "@mikro-orm/nestjs": "^6.0.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.0.0",
    "better-sqlite3": "12.10.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@mikro-orm/mysql": "^6.6.14",
    "@mikro-orm/postgresql": "^6.0.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@nestjs/typeorm": "^11.0.3",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.10.7",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "conventional-changelog-conventionalcommits": "7.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "fallow": "^2.96.0",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "lerna": "9.0.7",
    "prettier": "^3.4.2",
    "semver": "^7.8.4",
    "supertest": "^7.0.0",
    "testcontainers": "^12.0.2",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "overrides": {
    "better-sqlite3": "12.10.1",
    "tmp": "0.2.7",
    "form-data": "4.0.6",
    "multer": "2.2.0",
    "tar": "7.5.16",
    "node-gyp": {
      "undici": "6.27.0"
    },
    "testcontainers": {
      "undici": "8.5.0",
      "archiver": "7.0.1"
    },
    "js-yaml": "4.2.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": "(src|apps).*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "transformIgnorePatterns": [
      "/node_modules/",
      "<rootDir>/libs/cap-storage-prisma/prisma/generated/"
    ],
    "collectCoverageFrom": [
      "libs/**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "coveragePathIgnorePatterns": [
      "libs/cap-nest/src/testing/"
    ],
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/libs/",
      "<rootDir>/apps/"
    ],
    "moduleNameMapper": {
      "^@mikara89/cap-core(|/.*)$": "<rootDir>/libs/cap-core/src/$1",
      "^@mikara89/cap-testing(|/.*)$": "<rootDir>/libs/cap-testing/src/$1",
      "^@mikara89/cap-nest(|/.*)$": "<rootDir>/libs/cap-nest/src/$1",
      "^@mikara89/cap-express(|/.*)$": "<rootDir>/libs/cap-express/src/$1",
      "^@mikara89/cap-dashboard-core(|/.*)$": "<rootDir>/libs/cap-dashboard-core/src/$1",
      "^@mikara89/cap-dashboard-nest(|/.*)$": "<rootDir>/libs/cap-dashboard-nest/src/$1",
      "^@mikara89/cap-dashboard-express(|/.*)$": "<rootDir>/libs/cap-dashboard-express/src/$1",
      "^@mikara89/cap-storage-mikro-orm(|/.*)$": "<rootDir>/libs/cap-storage-mikro-orm/src/$1",
      "^@mikara89/cap-storage-knex(|/.*)$": "<rootDir>/libs/cap-storage-knex/src/$1",
      "^@mikara89/cap-storage-typeorm(|/.*)$": "<rootDir>/libs/cap-storage-typeorm/src/$1",
      "^@mikara89/cap-storage-prisma(|/.*)$": "<rootDir>/libs/cap-storage-prisma/src/$1",
      "^@mikara89/cap-transport-azure-servicebus(|/.*)$": "<rootDir>/libs/cap-transport-azure-servicebus/src/$1",
      "^@mikara89/cap-transport-nestjs-microservices(|/.*)$": "<rootDir>/libs/cap-transport-nestjs-microservices/src/$1",
      "^@mikara89/cap-transport-rabbitmq(|/.*)$": "<rootDir>/libs/cap-transport-rabbitmq/src/$1",
      "^@mikara89/cap-transport-kafka(|/.*)$": "<rootDir>/libs/cap-transport-kafka/src/$1",
      "^@mikara89/cap-transport-aws-sns-sqs(|/.*)$": "<rootDir>/libs/cap-transport-aws-sns-sqs/src/$1",
      "^@mikara89/cap-dashboard(|/.*)$": "<rootDir>/libs/cap-dashboard/src/$1"
    }
  }
}
