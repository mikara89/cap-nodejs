{
  "name": "cap",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "workspaces": [
    "apps/*",
    "libs/*",
    "packages/*"
  ],
  "license": "UNLICENSED",
  "scripts": {
    "build": "npm run build:libs && nest build",
    "build:libs": "npm run build:lib:cap-nest && npm run build:lib:cap-dashboard && npm run build:lib:storage && npm run build:lib:transport",
    "bootstrap": "npm install",
    "build:libs:lerna": "npx lerna run build --stream",
    "release": "npx lerna publish --conventional-commits --yes",
    "build:lib:cap-nest": "cd libs/cap-nest && tsc -p tsconfig.lib.json",
    "build:lib:cap-dashboard": "npm run build --workspace @cap/cap-dashboard",
    "build:lib:storage": "cd libs/storage-mikro-orm && tsc -p tsconfig.lib.json",
    "build:lib:transport": "cd libs/transport-azure-servicebus && tsc -p tsconfig.lib.json",
    "prestart": "npm run build",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start cap-test-app",
    "start:dev": "nest start cap-test-app --watch",
    "start:debug": "nest start cap-test-app --debug --watch",
    "start:prod": "node dist/apps/cap-test-app/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:check": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "pack:dry-run": "npm pack --dry-run --workspace @cap/cap-nest && npm pack --dry-run --workspace @cap/cap-dashboard && npm pack --dry-run --workspace @cap/mikroorm-storage && npm pack --dry-run --workspace @cap/azure-servicebus-transport",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:lib:cap-nest": "jest --testPathPattern=libs/cap-nest",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./apps/cap-test-app/test/jest-e2e.json",
    "test:integration": "jest --config ./apps/cap-test-app/test/jest-integration.json"
  },
  "dependencies": {
    "@mikro-orm/better-sqlite": "^6.0.0",
    "@mikro-orm/core": "^6.0.0",
    "@mikro-orm/nestjs": "^6.0.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.0.0",
    "@nestjs/serve-static": "5.0.4",
    "better-sqlite3": "11.10.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@mikro-orm/postgresql": "^6.0.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.7",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "pg": "^8.11.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "testcontainers": "^9.3.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "lerna": "^9.0.1"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "libs/**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "coveragePathIgnorePatterns": [
      "libs/cap-nest/src/testing/"
    ],
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/libs/",
      "<rootDir>/apps/"
    ],
    "moduleNameMapper": {
      "^@cap/cap-nest(|/.*)$": "<rootDir>/libs/cap-nest/src/$1",
      "^@cap/mikroorm-storage(|/.*)$": "<rootDir>/libs/storage-mikro-orm/src/$1",
      "^@cap/azure-servicebus-transport(|/.*)$": "<rootDir>/libs/transport-azure-servicebus/src/$1",
      "^@cap/cap-dashboard(|/.*)$": "<rootDir>/libs/cap-dashboard/src/$1"
    }
  }
}
