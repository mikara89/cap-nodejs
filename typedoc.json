{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": [
    "libs/cap-core/src/index.ts",
    "libs/cap-testing/src/index.ts",
    "libs/cap-nest/src/index.ts",
    "libs/cap-express/src/index.ts",
    "libs/cap-storage-mikro-orm/src/index.ts",
    "libs/cap-transport-azure-servicebus/src/index.ts",
    "libs/cap-transport-nestjs-microservices/src/index.ts",
    "libs/cap-dashboard-core/src/index.ts",
    "libs/cap-dashboard-nest/src/index.ts",
    "libs/cap-dashboard-express/src/index.ts"
  ],
  "entryPointStrategy": "expand",
  "name": "CAP for NestJS API",
  "tsconfig": "tsconfig.typedoc.json",
  "out": "docs/api",
  "plugin": ["typedoc-plugin-markdown"],
  "readme": "none",
  "excludePrivate": true,
  "excludeProtected": true,
  "excludeInternal": true,
  "hideGenerator": true,
  "gitRevision": "main"
}
