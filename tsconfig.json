{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "es2022",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false,
    "paths": {
      "@cap/cap-nest": [
        "libs/cap-nest/dist"
      ],
      "@cap/cap-nest/*": [
        "libs/cap-nest/dist/*"
      ],
      "@cap/mikroorm-storage": [
        "libs/storage-mikro-orm/dist"
      ],
      "@cap/mikroorm-storage/*": [
        "libs/storage-mikro-orm/dist/*"
      ],
      "@cap/azure-servicebus-transport": [
        "libs/transport-azure-servicebus/dist"
      ],
      "@cap/azure-servicebus-transport/*": [
        "libs/transport-azure-servicebus/dist/*"
      ],
      "@cap/cap-dashboard": [
        "libs/cap-dashboard/dist"
      ],
      "@cap/cap-dashboard/*": [
        "libs/cap-dashboard/dist/*"
      ]
    }
  },
  "include": [
    "apps/**/*",
    "types/**/*.d.ts"
  ]
}