{
    "$schema": "./node_modules/lerna/node_modules/nx/schemas/nx-schema.json",
    "namedInputs": {
        "default": [
            "{projectRoot}/**/*"
        ],
        "production": [
            "default",
            "!{projectRoot}/test/**/*",
            "!{projectRoot}/**/*.spec.ts",
            "!{projectRoot}/**/*.test.ts",
            "!{projectRoot}/**/__tests__/**",
            "!{projectRoot}/**/fixtures/**"
        ],
        "sharedGlobals": [
            "{workspaceRoot}/tsconfig.json",
            "{workspaceRoot}/tsconfig.build.json",
            "{workspaceRoot}/tsconfig.eslint.json",
            "{workspaceRoot}/eslint.config.mjs",
            "{workspaceRoot}/package.json",
            "{workspaceRoot}/lerna.json",
            "{workspaceRoot}/nx.json",
            "{workspaceRoot}/jest.config.ts",
            "{workspaceRoot}/nest-cli.json"
        ]
    },
    "targetDefaults": {
        "build": {
            "dependsOn": [
                "^build"
            ],
            "inputs": [
                "production",
                "^production",
                "sharedGlobals"
            ],
            "outputs": [
                "{projectRoot}/dist"
            ],
            "cache": true
        },
        "lint": {
            "inputs": [
                "default",
                "sharedGlobals"
            ],
            "cache": true
        },
        "test": {
            "dependsOn": [
                "build"
            ],
            "inputs": [
                "default",
                "^production",
                "sharedGlobals"
            ],
            "cache": true
        }
    },
    "defaultBase": "main"
}